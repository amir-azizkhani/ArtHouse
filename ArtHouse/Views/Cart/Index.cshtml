@model ArtHouse.ViewModels.Cart.CartViewModel
@using System.Linq

<div class="container mt-5">

    <h2 class="mb-4">
        🛒 Your Cart
    </h2>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info">
            Your cart is empty.
        </div>
    }
    else
    {
        <table class="table table-striped">

            <thead class="table-dark">

                <tr>

                    <th>Image</th>

                    <th>Product</th>

                    <th>Price</th>

                    <th>Quantity</th>

                    <th>Subtotal</th>

                    <th>Actions</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.Items)
                {
                    <tr>

                        <td>

                            @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                            {
                                <img src="@item.ProductImageUrl"
                                     style="width:60px;height:60px;object-fit:cover;" />
                            }

                        </td>

                        <td>

                            @item.ProductTitle

                        </td>

                        <td>

                            @item.UnitPrice.ToString("N0")

                        </td>

                        <td>

                            <div class="d-flex align-items-center gap-2">

                                <form asp-controller="Cart"
                                      asp-action="DecreaseQuantity"
                                      method="post">

                                    <input type="hidden"
                                           name="cartItemId"
                                           value="@item.CartItemId" />

                                    <button type="submit"
                                            class="btn btn-sm btn-warning">

                                        -

                                    </button>

                                </form>

                                <span class="fw-bold">

                                    @item.Quantity

                                </span>

                                <form asp-controller="Cart"
                                      asp-action="IncreaseQuantity"
                                      method="post">

                                    <input type="hidden"
                                           name="cartItemId"
                                           value="@item.CartItemId" />

                                    <button type="submit"
                                            class="btn btn-sm btn-success">

                                        +

                                    </button>

                                </form>

                            </div>

                        </td>

                        <td>

                            @item.SubTotal.ToString("N0")

                        </td>

                        <td>

                            <form asp-controller="Cart"
                                  asp-action="Remove"
                                  method="post">

                                <input type="hidden"
                                       name="cartItemId"
                                       value="@item.CartItemId" />

                                <button type="submit"
                                        class="btn btn-sm btn-danger">

                                    🗑 Remove

                                </button>

                            </form>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <div class="text-end">

            <h4>

                Total :

                @Model.TotalPrice.ToString("N0")

            </h4>

        </div>
    }

</div>